{
  "name": "espa-radar",
  "version": "0.1.0",
  "private": true,
  "description": "Ενοποιημένος scraper & βάση για ενεργά χρηματοδοτικά προγράμματα (ΕΣΠΑ, Ταμείο Ανάκαμψης, Αναπτυξιακός, Περιφερειακά) με matching engine.",
  "type": "module",
  "scripts": {
    "scrape": "tsx src/run.ts",
    "scrape:one": "tsx src/run.ts --source",
    "match": "tsx src/match.ts",
    "export": "tsx src/export.ts",
    "anatheorisi:build": "tsx src/anatheorisi-build.ts",
    "extract-budget": "tsx src/extract-budget.ts",
    "budget-api": "tsx src/budget-api.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.0.379",
    "playwright": "^1.48.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
